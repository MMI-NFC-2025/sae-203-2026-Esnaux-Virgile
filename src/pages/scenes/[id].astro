---
import Layout from "../../layouts/Layout.astro";
import { pb } from "../../../backend/backend.mjs";

export function toSlug(name: string): string {
    return name
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9]+/g, "");
}

const { id } = Astro.params;

let scene: any = null;
try {
    const all = await pb.collection("scene").getFullList();
    scene = all.find((s) => toSlug(s.nom_scene) === id) ?? null;
} catch (e) {
    console.error("Erreur PocketBase:", e);
}

if (!scene) {
    return Astro.redirect("/scenes");
}

const imgUrl = scene.photo_scene
    ? pb.files.getURL(scene, scene.photo_scene)
    : "";
---

<Layout title={`${scene.nom_scene} — LUMIMIX 2026`}>
    <!-- HERO -->
    <section
        class="relative w-full overflow-hidden -mt-16"
        style="height: clamp(400px, 70vh, 650px);"
    >
        {
            imgUrl && (
                <img
                    src={imgUrl}
                    alt={scene.nom_scene}
                    class="absolute inset-0 w-full h-full object-cover object-center"
                    loading="eager"
                />
            )
        }
        <div
            class="absolute inset-0 bg-linear-to-t from-black/90 via-black/30 to-black/50"
        >
        </div>

        <!-- Contenu centré -->
        <div
            class="absolute inset-0 flex flex-col items-center justify-center px-4 z-10 text-center pt-16"
        >
            <h1
                class="text-page-title font-black uppercase leading-none text-white drop-shadow-lg mb-5"
            >
                {scene.nom_scene.toUpperCase()}
            </h1>
            <a
                href="/scenes"
                class="text-white text-xs md:text-sm uppercase tracking-widest underline underline-offset-4 hover:text-rose transition-colors"
            >
                ← Retour
            </a>
        </div>
    </section>

    <!-- DESCRIPTION -->
    <section class="bg-black text-white px-6 md:px-16 py-14 max-w-3xl mx-auto">
        {
            scene.description_scene && (
                <p class="text-body-title font-body leading-relaxed text-white/90">
                    {scene.description_scene}
                </p>
            )
        }
        {
            scene.capacite_scene && (
                <p class="text-white/50 text-sm uppercase tracking-widest mt-6">
                    Capacité : {scene.capacite_scene} personnes
                </p>
            )
        }
    </section>
</Layout>
