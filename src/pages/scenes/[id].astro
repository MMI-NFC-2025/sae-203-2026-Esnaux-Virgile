---
import Layout from "../../layouts/Layout.astro";
import { pb } from "../../../backend/backend.mjs";

export function toSlug(name: string): string {
    return name
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9]+/g, "");
}

const moisFR = [
    "JANV",
    "FÉVR",
    "MARS",
    "AVR",
    "MAI",
    "JUIN",
    "JUIL",
    "AOUT",
    "SEPT",
    "OCT",
    "NOV",
    "DÉC",
];

function formatDay(dateStr: string): string {
    const d = new Date(dateStr);
    return `${d.getUTCDate().toString().padStart(2, "0")} ${moisFR[d.getUTCMonth()]}`;
}

const { id } = Astro.params;

let scene: any = null;
let artistes: any[] = [];

try {
    const all = await pb.collection("scene").getFullList();
    scene = all.find((s) => toSlug(s.nom_scene) === id) ?? null;

    if (scene) {
        artistes = await pb.collection("artiste").getFullList({
            sort: "+date_artiste",
            filter: `scene_artiste = "${scene.id}"`,
        });
    }
} catch (e) {
    console.error("Erreur PocketBase:", e);
}

if (!scene) {
    return Astro.redirect("/scenes");
}

const imgUrl = scene.photo_scene
    ? pb.files.getURL(scene, scene.photo_scene)
    : "";

// Grouper les artistes par date (jour)
const byDate = new Map<string, any[]>();
for (const a of artistes) {
    const day = formatDay(a.date_artiste);
    if (!byDate.has(day)) byDate.set(day, []);
    byDate.get(day)!.push(a);
}
---

<Layout title={`${scene.nom_scene}`}>
    <!-- HERO : image seule, derrière la navbar -->
    <section
        class="relative w-full overflow-hidden -mt-16"
        style="height: clamp(300px, 55vh, 560px);"
    >
        {
            imgUrl && (
                <img
                    src={imgUrl}
                    alt={scene.nom_scene}
                    class="absolute inset-0 w-full h-full object-cover object-center"
                    loading="eager"
                />
            )
        }
        <!-- léger gradient bas pour transition douce vers le fond noir -->
        <div
            class="absolute inset-0 bg-linear-to-t from-black via-transparent to-black/40"
        >
        </div>
    </section>

    <!-- CONTENU -->
    <section
        class="bg-black text-white px-5 md:px-16 pt-6 pb-20 max-w-3xl mx-auto"
    >
        <!-- Retour -->
        <a
            href="/scenes"
            aria-label="Retour à la liste des scènes"
            class="text-white text-xs uppercase tracking-widest underline underline-offset-4 text-center hover:text-rose transition-colors block mb-5"
        >
            ← RETOUR
        </a>

        <!-- Nom de la scène -->
        <h1
            class="text-page-title font-black uppercase leading-none text-white mb-10"
        >
            {scene.nom_scene.toUpperCase()}
        </h1>

        <!-- Artistes sur cette scène -->
        {
            artistes.length > 0 && (
                <div class="mb-10">
                    <h2 class="text-body-title font-black uppercase text-white mb-6">
                        ARTISTES SUR CETTE SCÈNE
                    </h2>
                    {[...byDate.entries()].map(([day, arts]) => (
                        <div class="mb-5">
                            <p
                                class="font-black tracking-widest text-sm mb-2"
                                style="color: var(--color-rose);"
                            >
                                {day}
                            </p>
                            <div class="flex flex-col gap-1 md:grid md:grid-cols-2 md:gap-x-8">
                                {arts.map((a) => (
                                    <a
                                        href={`/artistes/${toSlug(a.nom_artiste)}`}
                                        class="text-white font-body text-body hover:text-rose transition-colors pl-4"
                                    >
                                        {a.nom_artiste.toUpperCase()}
                                    </a>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            )
        }

        <!-- Description -->
        {
            scene.description_scene && (
                <div class="mb-8">
                    <p
                        class="font-black tracking-widest text-sm mb-3"
                        style="color: var(--color-rose);"
                    >
                        DESCRIPTION
                    </p>
                    <p class="text-white/90 text-body font-body leading-relaxed pl-4">
                        {scene.description_scene}
                    </p>
                </div>
            )
        }

        <!-- Capacité -->
        {
            scene.capacite_scene && (
                <div>
                    <p
                        class="font-black tracking-widest text-sm mb-2"
                        style="color: var(--color-rose);"
                    >
                        CAPACITÉ
                    </p>
                    <p class="text-white/80 text-body font-body pl-4">
                        {scene.capacite_scene} Personnes
                    </p>
                </div>
            )
        }
    </section>
</Layout>
