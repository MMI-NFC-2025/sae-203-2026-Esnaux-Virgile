---
import Layout from "../../layouts/Layout.astro";
import { pb } from "../../../backend/backend.mjs";
import type { GetStaticPaths } from "astro";

export function toSlug(name: string): string {
    return name
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9]+/g, "");
}

export const getStaticPaths: GetStaticPaths = async () => {
    const artistes = await pb.collection("artiste").getFullList({
        expand: "scene_artiste",
    });

    return artistes.map((artiste) => ({
        params: { id: toSlug(artiste.nom_artiste) },
        props: { artiste },
    }));
};

const { artiste } = Astro.props as { artiste: any };

const imgUrl = artiste.photo_artiste
    ? pb.files.getURL(artiste, artiste.photo_artiste)
    : "";
---

<Layout title={`${artiste.nom_artiste} — LUMIMIX 2026`}>
    <section class="bg-black text-white min-h-screen pt-16 px-4">
        <div class="text-center py-14">
            <h1 class="text-page-title font-black uppercase leading-none">
                {artiste.nom_artiste.toUpperCase()}
            </h1>
        </div>
        {
            imgUrl && (
                <div class="max-w-xl mx-auto rounded-2xl overflow-hidden">
                    <img
                        src={imgUrl}
                        alt={artiste.nom_artiste}
                        class="w-full object-cover"
                        loading="eager"
                    />
                </div>
            )
        }
        <div class="text-center mt-10">
            <a
                href="/programmation"
                class="text-white/50 uppercase tracking-widest text-sm hover:text-rose transition-colors"
            >
                ← Retour à la programmation
            </a>
        </div>
    </section>
</Layout>
