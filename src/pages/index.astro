---
import Layout from "../layouts/Layout.astro";
import Carousel from "../components/Carousel.astro";
import { Image } from "astro:assets";
import { pb } from "../lib/pocketbase.js";
import heroGif from "../assets/img/Hero_animee_accueil.gif";
import descImg from "../assets/img/accueil_description_img.avif";
import redbullImg from "../assets/img/redbull_img.avif";

let artistes: any[] = [];
try {
	artistes = await pb
		.collection("artiste")
		.getFullList({ sort: "+nom_artiste" });
} catch (e) {
	console.error("Erreur PocketBase:", e);
}
---

<Layout title="LUMIMIX 2026 - Accueil">
	<!-- ——— HERO ——— -->
	<section class="bg-black text-white text-center px-4 pt-10 pb-12">
		<p class="text-rose font-bold text-3xl uppercase tracking-widest mb-1">
			Festival 2026
		</p>

		<h1
			class="text-7xl md:text-9xl font-black uppercase leading-none mb-2"
			style="text-shadow: 0 0 20px #FFFFFF;"
		>
			LUMIMIX
		</h1>

		<p
			class="text-xs md:text-2xl uppercase tracking-[0.18em] text-white/80 mb-8"
		>
			OSE LA LUMIÈRE ET OSE LE SON
		</p>

		<!-- GIF cropé, responsive -->
		<div
			class="mx-auto mb-8 overflow-hidden rounded-full"
			style="width: clamp(180px, 60vw, 380px); height: clamp(180px, 60vw, 380px);"
		>
			<img
				src={heroGif?.src ?? heroGif}
				alt="Lumimix festival — animation"
				class="w-full h-full object-cover object-center scale-[1.15] origin-center"
			/>
		</div>

		<div
			class="grid grid-cols-3 items-center justify-items-center mx-auto mb-6"
			style="max-width: clamp(200px, 60vw, 300px);"
		>
			<div class="text-center">
				<p
					class="text-6xl md:text-7xl font-black leading-none"
					style="text-shadow: 0 0 20px #FFFFFF;"
				>
					07
				</p>
				<p class="text-xs font-bold uppercase tracking-[0.2em] mt-1">
					AOÛT
				</p>
			</div>
			<div class="text-5xl md:text-6xl font-thin text-white/40">|</div>
			<div class="text-center">
				<p
					class="text-6xl md:text-7xl font-black leading-none"
					style="text-shadow: 0 0 20px #FFFFFF;"
				>
					08
				</p>
				<p class="text-xs font-bold uppercase tracking-[0.2em] mt-1">
					AOÛT
				</p>
			</div>
		</div>

		<p class="text-xs uppercase tracking-[0.35em] text-white/60 mb-8">
			DJ &nbsp;&nbsp; ELECTRO &nbsp;&nbsp; RAGGAE
		</p>

		<p class="text-lg md:text-xl font-black uppercase">
			PRESQU'ÎLE DE MALSAUCY
		</p>
		<p class="text-sm uppercase tracking-wider text-white/50 mt-1">
			BELFORT
		</p>
	</section>

	<!-- ——— PROGRAMMATION ——— -->
	<section class="bg-black text-white py-12 px-4">
		<div class="text-center mb-6">
			<p class="text-sm uppercase tracking-[0.2em] text-white/40 mb-1">
				2026
			</p>
			<div class="flex items-center justify-center gap-4">
				<h2 class="text-4xl md:text-5xl font-black uppercase">
					PROGRAMMATION
				</h2>
			</div>
		</div>

		<div class="max-w-2xl mx-auto mb-10">
			{
				artistes.length > 0 ? (
					<div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-1">
						{artistes.map((a, i) => (
							<p
								class={`text-sm md:text-base font-bold uppercase leading-loose ${i % 2 === 0 ? "text-white" : "text-rose"}`}
							>
								{a.nom_artiste ?? a.name}
							</p>
						))}
					</div>
				) : (
					<p class="text-center text-white/40 py-8">
						Programmation bientôt disponible
					</p>
				)
			}
		</div>

		<div class="text-center">
			<a
				href="/programmation"
				class="inline-block border border-white text-white font-black uppercase text-xs tracking-widest px-10 py-3 rounded-full hover:bg-white hover:text-black transition-colors"
			>
				PROGRAMMATION
			</a>
		</div>
	</section>

	<!-- ——— VIBRATIONS ——— -->
	<section class="bg-black text-white py-12 px-4">
		<div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-10 items-center">
			<!-- Texte -->
			<div>
				<h2
					class="text-3xl md:text-4xl font-black uppercase leading-tight mb-8"
				>
					PLUSIEURS NUITS DE<br />VIBRATIONS ÉLECTRIQUES
				</h2>

				<p
					class="text-sm md:text-base text-white/75 leading-relaxed mb-4"
				>
					Plongez dans un univers musical vibrant où les pulsations
					électro se mêlent aux grooves chaleureux du reggae. Durant
					plusieurs nuits de fête, le festival ouvre un espace sans
					limites, célébrant la richesse et le mélange des styles.
					DJs, producteurs et artistes vous embarquent dans une
					programmation variée : Electro, DJ et bien d'autres énergies
					sonores.
				</p>
				<p
					class="text-sm md:text-base text-white/75 leading-relaxed mb-10"
				>
					Préparez-vous à vivre une série de nuits inoubliables, où
					chaque festivalier trouvera la vibe qui fera résonner son
					âme !
				</p>

				<a
					href="/festival"
					class="inline-block border border-white text-white font-black uppercase text-xs tracking-widest px-10 py-3 rounded-full hover:bg-white hover:text-black transition-colors"
				>
					HISTORIQUE
				</a>
			</div>

			<!-- Image -->
			<Image
				src={descImg}
				alt="Ambiance Lumimix"
				class="w-full h-auto rounded-lg md:order-last order-first"
			/>
		</div>
	</section>

	<!-- ——— PARTENAIRES ——— -->
	<section class="bg-black text-white py-12 px-4">
		<h2 class="text-3xl md:text-4xl font-black uppercase text-center mb-8">
			NOS PARTENAIRES
		</h2>

		<div class="max-w-sm mx-auto">
			<Carousel>
				<!-- Red Bull -->
				<div
					class="snap-center shrink-0 flex items-center justify-center w-48 px-6"
				>
					<Image
						src={redbullImg}
						alt="Red Bull"
						class="max-h-24 w-auto object-contain"
					/>
				</div>
				<!-- Autres partenaires -->
				<div
					class="snap-center shrink-0 flex items-center justify-center w-48 px-6"
				>
					<p
						class="text-white/40 text-xs text-center uppercase tracking-widest font-bold"
					>
						Autres partenaires<br />à venir
					</p>
				</div>
			</Carousel>
		</div>
	</section>
</Layout>
