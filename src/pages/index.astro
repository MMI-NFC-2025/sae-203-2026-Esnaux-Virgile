---
import Layout from "../layouts/LayoutAccueil.astro";
import Carousel from "../components/Carousel.astro";
import { Image } from "astro:assets";
import { getArtistesByOrder } from "../../backend/backend.mjs";
import heroGif from "../assets/img/Hero_animee_accueil.gif";
import descImg from "../assets/img/accueil_description_img.avif";
import redbullImg from "../assets/img/redbull_img.avif";

let artistes: any[] = [];
try {
	artistes = await getArtistesByOrder();
} catch (e) {
	console.error("Erreur PocketBase:", e);
}
---

<Layout title="LUMIMIX 2026 - Accueil">
	<!-- ——— HERO ——— -->
	<section class="bg-black text-white overflow-hidden px-4 pt-10 pb-12">
		<div
			class="max-w-6xl mx-auto flex flex-col items-center md:grid md:grid-cols-2 md:gap-16"
		>
			<!-- Texte haut : badge + titre + sous-titre -->
			<div class="text-center md:text-left w-full">
				<p
					class="text-rose font-bold uppercase tracking-widest mb-1"
					style="font-size: clamp(0.75rem, 3vw, 1rem);"
				>
					Festival 2026
				</p>
				<h1
					class="font-brand font-black uppercase leading-none mb-2"
					style="font-size: clamp(3.5rem, 18vw, 7rem); text-shadow: 0 0 20px #FFFFFF;"
				>
					LUMIMIX
				</h1>
				<p
					class="uppercase tracking-[0.18em] text-white/80 mb-8"
					style="font-size: clamp(0.6rem, 2.5vw, 1rem);"
				>
					OSE LA LUMIÈRE ET OSE LE SON
				</p>
			</div>

			<!-- GIF : après le titre sur mobile, colonne droite sur desktop -->
			<div
				class="mx-auto mb-8 overflow-hidden rounded-full md:col-start-2 md:row-span-2 md:self-center md:mb-0"
				style="width: clamp(11.25rem, 60vw, 23.75rem); height: clamp(11.25rem, 60vw, 23.75rem);"
			>
				<img
					src={heroGif?.src ?? heroGif}
					alt="Lumimix festival — animation"
					class="w-full h-full object-cover object-center scale-[1.15] origin-center"
				/>
			</div>

			<!-- Texte bas : dates + genres + lieu -->
			<div class="md:text-left w-full">
				<div
					class="grid grid-cols-3 items-center justify-items-center mx-auto md:mx-0 mb-6"
					style="max-width: clamp(12.5rem, 60vw, 18.75rem);"
				>
					<div class="text-center">
						<p
							class="font-black leading-none"
							style="font-size: clamp(2.5rem, 14vw, 4.5rem); text-shadow: 0 0 20px #FFFFFF;"
						>
							07
						</p>
						<p
							class="text-xs font-bold uppercase tracking-[0.2em] mt-1"
						>
							AOÛT
						</p>
					</div>
					<!-- Trait gradient rose → bleu -->
					<div
						class="self-center rounded-full"
						style="width: 0.125rem; height: clamp(3rem, 12vw, 5rem); background: linear-gradient(to top, #F61FF1, #1F8FF6);"
					>
					</div>
					<div class="text-center">
						<p
							class="font-black leading-none"
							style="font-size: clamp(2.5rem, 14vw, 4.5rem); text-shadow: 0 0 20px #FFFFFF;"
						>
							08
						</p>
						<p
							class="text-xs font-bold uppercase tracking-[0.2em] mt-1"
						>
							AOÛT
						</p>
					</div>
				</div>

				<p class="text-xs uppercase tracking-[0.35em] mb-8">
					<span style="color: #00DAFF;">DJ</span> &nbsp;&nbsp; <span style="color: #F61FF1;">ELECTRO</span> &nbsp;&nbsp; <span style="color: #B617FF;">RAGGAE</span>
				</p>
				<p
					class="font-black uppercase"
					style="font-size: clamp(1rem, 4vw, 1.25rem);"
				>
					PRESQU'ÎLE DE MALSAUCY
				</p>
				<p class="text-sm uppercase tracking-wider text-white/50 mt-1">
					BELFORT
				</p>
			</div>
		</div>
	</section>

	<!-- ——— PROGRAMMATION ——— -->
	<section class="bg-black text-white py-12 px-4">
		<div class="text-center mb-6">
			<p class="text-2xl uppercase tracking-[0.2em] text-white/50 mb-1">
				2026
			</p>
			<div class="flex items-center justify-center gap-4">
				<h2 class="text-page-title font-black uppercase">
					PROGRAMMATION
				</h2>
			</div>
		</div>

		<div class="max-w-2xl mx-auto mb-10">
			{
				artistes.length > 0 ? (
					<div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-1">
						{artistes.map((a, i) => (
							<p
								class={`text-sm md:text-body-title font-bold uppercase leading-loose ${i % 2 === 0 ? "text-white" : "text-rose"}`}
							>
								{a.nom_artiste ?? a.name}
							</p>
						))}
					</div>
				) : (
					<p class="text-center text-white/40 py-8">
						Programmation bientôt disponible
					</p>
				)
			}
		</div>

		<div class="text-center">
			<a
				href="/programmation"
				class="inline-block border border-white text-white font-black uppercase text-xs tracking-widest px-10 py-2 rounded-full hover:bg-white hover:text-black transition-colors"
			>
				PROGRAMMATION
			</a>
		</div>
	</section>

	<!-- ——— VIBRATIONS ——— -->
	<section class="bg-black text-white py-12 px-4">
		<div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-10 items-center">
			<!-- Texte -->
			<div>
				<h2
					class="text-section-title font-black uppercase leading-tight mb-8"
				>
					PLUSIEURS NUITS DE<br />VIBRATIONS ÉLECTRIQUES
				</h2>

				<p class="text-body text-white leading-relaxed mb-4">
					Plongez dans un univers musical vibrant où les pulsations
					électro se mêlent aux grooves chaleureux du reggae. Durant
					plusieurs nuits de fête, le festival ouvre un espace sans
					limites, célébrant la richesse et le mélange des styles.
					DJs, producteurs et artistes vous embarquent dans une
					programmation variée : Electro, DJ et bien d'autres énergies
					sonores.
				</p>
				<p class="text-body text-white leading-relaxed mb-10 font-bold">
					Préparez-vous à vivre une série de nuits inoubliables, où
					chaque festivalier trouvera la vibe qui fera résonner son
					âme !
				</p>

				<a
					href="/festival"
					class="inline-block border border-white text-white font-black uppercase text-xs tracking-widest px-10 py-3 rounded-full hover:bg-white hover:text-black transition-colors"
				>
					HISTORIQUE
				</a>
			</div>

			<!-- Image -->
			<Image
				src={descImg}
				alt="Ambiance Lumimix"
				class="w-full h-auto rounded-lg md:order-last order-first"
			/>
		</div>
	</section>

	<!-- ——— PARTENAIRES ——— -->
	<section class="bg-black text-white py-12 px-4">
		<h2 class="text-section-title font-black uppercase text-center mb-8">
			NOS PARTENAIRES
		</h2>

		<div class="max-w-sm mx-auto">
			<Carousel>
				<!-- Red Bull -->
				<div
					class="snap-start shrink-0 w-full flex items-center justify-center py-2"
				>
					<Image
						src={redbullImg}
						alt="Red Bull"
						class="max-h-28 w-auto object-contain"
					/>
				</div>
				<!-- Autres partenaires -->
				<div
					class="snap-start shrink-0 w-full flex items-center justify-center py-2"
				>
					<p
						class="text-white/40 text-xs text-center uppercase tracking-widest font-bold"
					>
						Autres partenaires<br />à venir
					</p>
				</div>
			</Carousel>
		</div>
	</section>
</Layout>
