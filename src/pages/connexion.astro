---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Connexion">
    <!-- TITRE -->
    <section class="bg-black text-white pt-14 pb-8 px-4 text-center">
        <h1 class="text-page-title font-black uppercase leading-none">
            CONNEXION
        </h1>
    </section>

    <!-- VUE CONNECTÉ (cachée par défaut, affichée par JS) -->
    <section
        id="logged-in-view"
        class="hidden bg-black text-white px-6 md:px-16 pb-20 max-w-md md:max-w-2xl mx-auto flex flex-col gap-6"
    >
        <div
            class="rounded-2xl p-8 flex flex-col items-center gap-6 text-center"
            style="background: #2F212E; border: 2px solid #F61FF1;"
        >
            <div
                class="w-16 h-16 rounded-full flex items-center justify-center text-2xl font-black"
                style="background: #F61FF1;"
                id="user-avatar-initials"
            >
                ?
            </div>
            <div>
                <p
                    class="font-black text-white text-lg uppercase tracking-wide"
                >
                    Connecté
                </p>
                <p id="user-email-display" class="text-white/60 text-sm mt-1">
                </p>
            </div>
            <button
                id="logout-btn"
                type="button"
                class="w-full py-3 px-4 rounded-full font-black uppercase tracking-widest text-sm text-white hover:opacity-80 transition-opacity border-2"
                style="border-color: #F61FF1;"
            >
                Se déconnecter
            </button>
        </div>
    </section>

    <!-- CONTENU -->
    <section
        id="login-view"
        class="bg-black text-white px-6 md:px-16 pb-20 max-w-md md:max-w-2xl mx-auto flex flex-col gap-10"
    >
        <!-- Formulaire -->
        <form
            id="login-form"
            class="rounded-2xl p-8 flex flex-col gap-6"
            style="background: #2F212E; border: 2px solid #F61FF1;"
        >
            <!-- Email -->
            <div class="flex flex-col gap-1">
                <label
                    for="email"
                    class="font-black text-base"
                    style="color: #F61FF1;">Email</label
                >
                <input
                    id="email"
                    type="email"
                    name="email"
                    placeholder="Entrez votre Email ici..."
                    required
                    class="bg-transparent border-b py-2 text-white placeholder:text-white/40 outline-none"
                    style="border-bottom-color: rgba(255,255,255,0.4);"
                />
            </div>

            <!-- Mot de passe -->
            <div class="flex flex-col gap-1">
                <label
                    for="password"
                    class="font-black text-base"
                    style="color: #F61FF1;">Mot de passe</label
                >
                <input
                    id="password"
                    type="password"
                    name="password"
                    placeholder="Entrez votre mot de passe ici..."
                    required
                    minlength="8"
                    class="bg-transparent border-b py-2 text-white placeholder:text-white/40 outline-none"
                    style="border-bottom-color: rgba(255,255,255,0.4);"
                />
                <span class="text-white/30 text-xs">Minimum 8 caractères</span>
            </div>

            <!-- Submit -->
            <button
                type="submit"
                class="w-full py-3 px-4 rounded-full font-black uppercase tracking-widest text-sm text-white hover:opacity-80 transition-opacity mt-2"
                style="background: #F61FF1;"
            >
                Valider
            </button>

            <!-- Feedback -->
            <p id="form-feedback" class="text-center text-sm hidden"></p>
        </form>

        <!-- Modal inscription -->
        <div
            id="signup-modal"
            class="hidden fixed inset-0 z-50 flex items-center justify-center px-6"
        >
            <div class="absolute inset-0 bg-black/70" id="modal-backdrop"></div>
            <div
                class="relative rounded-2xl p-8 flex flex-col gap-6 max-w-sm w-full text-center"
                style="background: #2F212E; border: 2px solid #F61FF1;"
            >
                <p
                    class="font-black text-white text-lg uppercase tracking-wide"
                >
                    Compte introuvable
                </p>
                <p class="text-white/80 text-sm leading-relaxed">
                    Aucun compte ne correspond à cet email.<br />
                    Voulez-vous vous inscrire ?
                </p>
                <div class="flex flex-col gap-3">
                    <button
                        id="modal-signup"
                        type="button"
                        class="w-full py-3 px-4 rounded-full font-black uppercase tracking-widest text-sm text-white hover:opacity-80 transition-opacity"
                        style="background: #F61FF1;"
                    >
                        S'inscrire
                    </button>
                    <button
                        id="modal-cancel"
                        type="button"
                        class="w-full py-3 px-4 rounded-full font-black uppercase tracking-widest text-sm text-white/70 hover:text-white border border-white/30 hover:border-white/60 transition-colors"
                    >
                        Annuler
                    </button>
                </div>
            </div>
        </div>

        <!-- Modal inscription formulaire -->
        <div
            id="register-modal"
            class="hidden fixed inset-0 z-50 flex items-center justify-center px-6"
        >
            <div class="absolute inset-0 bg-black/70"></div>
            <div
                class="relative rounded-2xl p-8 flex flex-col gap-6 max-w-sm w-full"
                style="background: #2F212E; border: 2px solid #F61FF1;"
            >
                <p
                    class="font-black text-white text-lg uppercase tracking-wide text-center"
                >
                    Inscription
                </p>

                <form id="register-form" class="flex flex-col gap-6">
                    <div class="flex flex-col gap-1">
                        <label
                            class="font-black text-sm"
                            style="color: #F61FF1;">Email</label
                        >
                        <input
                            id="reg-email"
                            type="email"
                            name="reg-email"
                            placeholder="Entrez votre Email ici..."
                            required
                            class="bg-transparent border-b py-2 text-white placeholder:text-white/40 outline-none"
                            style="border-bottom-color: rgba(255,255,255,0.4);"
                        />
                    </div>
                    <div class="flex flex-col gap-1">
                        <label
                            class="font-black text-sm"
                            style="color: #F61FF1;">Mot de passe</label
                        >
                        <input
                            id="reg-password"
                            type="password"
                            name="reg-password"
                            placeholder="Entrez votre mot de passe ici..."
                            required
                            minlength="8"
                            class="bg-transparent border-b py-2 text-white placeholder:text-white/40 outline-none"
                            style="border-bottom-color: rgba(255,255,255,0.4);"
                        />
                        <span class="text-white/30 text-xs"
                            >Minimum 8 caractères</span
                        >
                    </div>
                    <button
                        type="submit"
                        class="w-full py-3 px-4 rounded-full font-black uppercase tracking-widest text-sm text-white hover:opacity-80 transition-opacity"
                        style="background: #F61FF1;"
                    >
                        Créer mon compte
                    </button>
                    <p
                        id="register-feedback"
                        class="text-center text-sm hidden"
                    >
                    </p>
                </form>

                <button
                    id="register-cancel"
                    type="button"
                    class="w-full py-2 text-white/50 hover:text-white text-sm transition-colors"
                >
                    Annuler
                </button>
            </div>
        </div>
    </section>

    <script>
        // Vérifier si déjà connecté
        const token = localStorage.getItem("pb_token");
        const user = localStorage.getItem("pb_user");
        const loginView = document.getElementById("login-view") as HTMLElement;
        const loggedInView = document.getElementById(
            "logged-in-view",
        ) as HTMLElement;

        if (token && user) {
            const parsed = JSON.parse(user);
            const email = parsed.email ?? "";
            const initials = email.charAt(0).toUpperCase();
            loginView.classList.add("hidden");
            loggedInView.classList.remove("hidden");
            loggedInView.style.display = "flex";
            (
                document.getElementById("user-email-display") as HTMLElement
            ).textContent = email;
            (
                document.getElementById("user-avatar-initials") as HTMLElement
            ).textContent = initials;
        }

        // Déconnexion
        document.getElementById("logout-btn")?.addEventListener("click", () => {
            localStorage.removeItem("pb_token");
            localStorage.removeItem("pb_user");
            window.location.reload();
        });

        const loginForm = document.getElementById(
            "login-form",
        ) as HTMLFormElement;
        const feedback = document.getElementById(
            "form-feedback",
        ) as HTMLParagraphElement;
        const signupModal = document.getElementById(
            "signup-modal",
        ) as HTMLElement;
        const registerModal = document.getElementById(
            "register-modal",
        ) as HTMLElement;

        // Connexion
        loginForm.addEventListener("submit", async (e) => {
            e.preventDefault();
            const email = (document.getElementById("email") as HTMLInputElement)
                .value;
            const password = (
                document.getElementById("password") as HTMLInputElement
            ).value;

            try {
                const res = await fetch(
                    "http://localhost:8090/api/collections/users/auth-with-password",
                    {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ identity: email, password }),
                    },
                );

                if (res.ok) {
                    const data = await res.json();
                    localStorage.setItem("pb_token", data.token);
                    localStorage.setItem(
                        "pb_user",
                        JSON.stringify(data.record),
                    );
                    window.location.href = "/";
                } else {
                    const err = await res.json();
                    console.error("Auth error:", err);
                    // Compte inexistant ou mauvais mdp
                    if (res.status === 400 || res.status === 404) {
                        signupModal.classList.remove("hidden");
                    } else {
                        feedback.textContent =
                            err?.message ?? "Email ou mot de passe incorrect.";
                        feedback.style.color = "#ff4444";
                        feedback.classList.remove("hidden");
                    }
                }
            } catch {
                feedback.textContent = "Impossible de contacter le serveur.";
                feedback.style.color = "#ff4444";
                feedback.classList.remove("hidden");
            }
        });

        // Fermer modal signup
        document
            .getElementById("modal-backdrop")
            ?.addEventListener("click", () => {
                signupModal.classList.add("hidden");
            });
        document
            .getElementById("modal-cancel")
            ?.addEventListener("click", () => {
                signupModal.classList.add("hidden");
            });

        // Ouvrir modal inscription
        document
            .getElementById("modal-signup")
            ?.addEventListener("click", () => {
                signupModal.classList.add("hidden");
                // Pré-remplir l'email
                const email = (
                    document.getElementById("email") as HTMLInputElement
                ).value;
                (
                    document.getElementById("reg-email") as HTMLInputElement
                ).value = email;
                registerModal.classList.remove("hidden");
            });

        // Fermer modal inscription
        document
            .getElementById("register-cancel")
            ?.addEventListener("click", () => {
                registerModal.classList.add("hidden");
            });

        // Inscription
        document
            .getElementById("register-form")
            ?.addEventListener("submit", async (e) => {
                e.preventDefault();
                const regEmail = (
                    document.getElementById("reg-email") as HTMLInputElement
                ).value;
                const regPassword = (
                    document.getElementById("reg-password") as HTMLInputElement
                ).value;
                const regFeedback = document.getElementById(
                    "register-feedback",
                ) as HTMLParagraphElement;

                try {
                    const res = await fetch(
                        "http://localhost:8090/api/collections/users/records",
                        {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({
                                email: regEmail,
                                password: regPassword,
                                passwordConfirm: regPassword,
                            }),
                        },
                    );

                    if (res.ok) {
                        // Connexion automatique après inscription
                        const authRes = await fetch(
                            "http://localhost:8090/api/collections/users/auth-with-password",
                            {
                                method: "POST",
                                headers: {
                                    "Content-Type": "application/json",
                                },
                                body: JSON.stringify({
                                    identity: regEmail,
                                    password: regPassword,
                                }),
                            },
                        );
                        if (authRes.ok) {
                            const data = await authRes.json();
                            localStorage.setItem("pb_token", data.token);
                            localStorage.setItem(
                                "pb_user",
                                JSON.stringify(data.record),
                            );
                            window.location.href = "/";
                        } else {
                            // Email verification requis — compte créé mais connexion impossible
                            registerModal.classList.add("hidden");
                            feedback.textContent =
                                "Compte créé ! Connectez-vous maintenant avec votre email et mot de passe.";
                            feedback.style.color = "#F61FF1";
                            feedback.classList.remove("hidden");
                        }
                    } else {
                        const err = await res.json();
                        regFeedback.textContent =
                            err?.message ?? "Erreur lors de l'inscription.";
                        regFeedback.style.color = "#ff4444";
                        regFeedback.classList.remove("hidden");
                    }
                } catch {
                    regFeedback.textContent =
                        "Impossible de contacter le serveur.";
                    regFeedback.style.color = "#ff4444";
                    regFeedback.classList.remove("hidden");
                }
            });
    </script>
</Layout>
