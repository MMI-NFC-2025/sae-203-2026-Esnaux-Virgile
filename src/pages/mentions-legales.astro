---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Mentions légales — LUMIMIX 2026">
    <!-- TITRE -->
    <section class="bg-black text-white pt-14 pb-8 px-4 text-center">
        <h1 class="text-page-title font-black uppercase leading-none">
            MENTIONS LÉGALES
        </h1>
    </section>

    <!-- CONTENU -->
    <section
        class="bg-black text-white px-6 md:px-16 pb-20 max-w-3xl mx-auto flex flex-col gap-8"
    >
        <!-- Éditeur du site -->
        <div>
            <p
                class="text-body-title uppercase tracking-widest text-sm mb-2"
                style="color: var(--color-rose);"
            >
                Éditeur du site
            </p>
            <p class="text-body font-body text-white/90 leading-relaxed">
                Ce site est édité par Léonie Pruniaux, dans le cadre d'un projet
                étudiant (SAE 105 — BUT MMI).<br />
                Établissement : IUT de Montbéliard<br />
                Adresse : Presqu'île de Malsaucy, Belfort<br />
                E-mail : lumimix@festival.com<br />
                Téléphone : 07 85 16 52 23
            </p>
        </div>

        <!-- Hébergeur -->
        <div>
            <p
                class="text-body-title uppercase tracking-widest text-sm mb-2"
                style="color: var(--color-rose);"
            >
                Hébergeur
            </p>
            <p class="text-body font-body text-white/90 leading-relaxed">
                Ce site est hébergé par [Nom de l'hébergeur]<br />
                Adresse : [Adresse de l'hébergeur]
            </p>
        </div>

        <!-- Données personnelles -->
        <div>
            <p
                class="text-body-title uppercase tracking-widest text-sm mb-2"
                style="color: var(--color-rose);"
            >
                Données personnelles
            </p>
            <p class="text-body font-body text-white/90 leading-relaxed">
                Ce site ne collecte aucune donnée personnelle sans votre
                consentement. Conformément au RGPD, vous disposez d'un droit
                d'accès, de rectification et de suppression de vos données. Pour
                toute demande : lumimix@festival.com<br />
                <br />
                Numéro de téléphone : 07 85 16 52 23<br />
                Adresse postale : Presqu'île de MALSAUCY Belfort
            </p>
        </div>

        <!-- Cookies -->
        <div>
            <p
                class="text-body-title uppercase tracking-widest text-sm mb-2"
                style="color: var(--color-rose);"
            >
                Cookies
            </p>
            <p class="text-body font-body text-white/90 leading-relaxed">
                Ce site peut utiliser des cookies techniques nécessaires à son
                fonctionnement. Aucun cookie publicitaire ou de tracking tiers
                n'est utilisé.
            </p>
        </div>
    </section>
</Layout>
