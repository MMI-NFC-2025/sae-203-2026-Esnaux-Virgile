---
import Layout from "../layouts/Layout.astro";
import CardArtiste from "../components/CardArtiste.astro";
import { pb } from "../../backend/backend.mjs";
import { toSlug } from "./artistes/[id].astro";

const moisFR = [
    "JANV",
    "FÉVR",
    "MARS",
    "AVR",
    "MAI",
    "JUIN",
    "JUIL",
    "AOUT",
    "SEPT",
    "OCT",
    "NOV",
    "DÉC",
];

function formatDay(dateStr: string): string {
    const d = new Date(dateStr);
    const day = d.getUTCDate().toString().padStart(2, "0");
    const month = moisFR[d.getUTCMonth()];
    return `${day} ${month}`;
}

let artistes: any[] = [];
try {
    artistes = await pb.collection("artiste").getFullList({
        sort: "+nom_artiste",
    });
} catch (e) {
    console.error("Erreur PocketBase:", e);
}

const noms = artistes.map((a) => a.nom_artiste).sort() as string[];
---

<Layout title="Artistes">
    <!-- TITRE -->
    <section class="bg-black text-white pt-14 pb-8 px-4 text-center">
        <h1 class="text-page-title font-black uppercase leading-none">
            ARTISTES
        </h1>
        <p class="text-page-title font-medium uppercase leading-none mt-3">
            2026
        </p>
    </section>

    <!-- FILTRE NOM -->
    <section class="bg-black px-4 pb-10 flex flex-col items-center gap-3">
        <div class="relative">
            <select
                id="filter-nom"
                class="appearance-none bg-transparent border border-white/60 text-white font-bold uppercase tracking-widest py-2 pl-6 pr-10 rounded-full cursor-pointer text-sm min-w-40 text-center"
            >
                <option value="">NOM</option>
                {noms.map((n) => <option value={n}>{n.toUpperCase()}</option>)}
            </select>
            <span
                class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-white text-xs"
                >&#8964;</span
            >
        </div>
    </section>

    <!-- CARDS ARTISTES -->
    <section
        id="artistes-list"
        class="bg-black px-4 pb-8 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4"
    >
        {
            artistes.map((artiste) => {
                const day = formatDay(artiste.date_artiste);
                const nom = artiste.nom_artiste;
                const imgUrl = artiste.photo_artiste
                    ? pb.files.getURL(artiste, artiste.photo_artiste)
                    : "";
                const slug = toSlug(nom);

                return (
                    <CardArtiste
                        imgUrl={imgUrl}
                        day={day}
                        nom={nom}
                        slug={slug}
                        small={true}
                        data-nom={nom}
                    />
                );
            })
        }
    </section>

    <!-- Mention -->
    <p class="text-white text-center text-xs uppercase tracking-[0.1rem] pb-8">
        ET BIEN D'AUTRES ENCORE...
    </p>
</Layout>

<script>
    const cards = document.querySelectorAll<HTMLElement>(".artiste-card");
    const selNom = document.getElementById("filter-nom") as HTMLSelectElement;

    function filterCards() {
        const nom = selNom.value;
        cards.forEach((card) => {
            const match = !nom || card.dataset.nom === nom;
            card.style.display = match ? "" : "none";
        });
    }

    selNom.addEventListener("change", filterCards);
</script>
