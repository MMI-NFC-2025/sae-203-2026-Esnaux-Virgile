---
import { Image } from "astro:assets";
import facebook from "../assets/img/facebook.svg";
import instagram from "../assets/img/instagram.svg";
import x from "../assets/img/x.svg";
import tiktok from "../assets/img/tiktok.svg";
import youtube from "../assets/img/youtube.svg";
---

<footer
  class="bg-black text-white pt-6 md:pt-10 pb-4 md:pb-6 text-center border-t border-white/10"
>
  <div class="px-4 md:px-16 max-w-lg md:max-w-3xl mx-auto">
    <p
      class="font-brand text-3xl md:text-6xl font-black tracking-widest mb-4 md:mb-6"
      style="text-shadow: 0 0 20px #FFFFFF;"
    >
      LUMIMIX
    </p>

    <div class="flex justify-center items-center gap-6 md:gap-12 mb-4 md:mb-6">
      <a
        href="https://www.facebook.com/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Facebook"
        class="hover:opacity-70 transition-opacity"
      >
        <Image
          src={facebook}
          alt="Facebook"
          width={36}
          height={36}
          class="md:w-24 md:h-24"
        />
      </a>
      <a
        href="https://x.com/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="X"
        class="hover:opacity-70 transition-opacity"
      >
        <Image src={x} alt="X" width={36} height={36} class="md:w-24 md:h-24" />
      </a>
      <a
        href="https://www.instagram.com/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="hover:opacity-70 transition-opacity"
      >
        <Image
          src={instagram}
          alt="Instagram"
          width={36}
          height={36}
          class="md:w-24 md:h-24"
        />
      </a>
      <a
        href="https://www.tiktok.com/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="TikTok"
        class="hover:opacity-70 transition-opacity"
      >
        <Image
          src={tiktok}
          alt="TikTok"
          width={36}
          height={36}
          class="md:w-24 md:h-24"
        />
      </a>
      <a
        href="https://www.youtube.com/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="YouTube"
        class="hover:opacity-70 transition-opacity"
      >
        <Image
          src={youtube}
          alt="YouTube"
          width={36}
          height={36}
          class="md:w-24 md:h-24"
        />
      </a>
    </div>

    <nav
      aria-label="Navigation secondaire"
      class="flex flex-col gap-2 md:gap-3 text-sm md:text-lg font-bold uppercase tracking-widest mb-4 md:mb-6"
    >
      <a href="/contact" class="hover:text-rose transition-colors">Contacts</a>
      <a href="/mentions-legales" class="hover:text-rose transition-colors"
        >Mentions legales</a
      >
    </nav>
    <div class="w-4/5 h-[0.1rem] bg-white mx-auto"></div>
    <p class="text-xs md:text-sm text-white mt-6">
      Site web par Leonie PRUNIAUX
    </p>
  </div>
</footer>
