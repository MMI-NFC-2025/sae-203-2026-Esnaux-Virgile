---
import { Image } from "astro:assets";
import facebook from "../assets/img/facebook.svg";
import instagram from "../assets/img/instagram.svg";
import x from "../assets/img/x.svg";
import tiktok from "../assets/img/tiktok.svg";
import youtube from "../assets/img/youtube.svg";
---

<footer
  class="bg-black text-white pt-12 pb-8 text-center border-t border-white/10"
>
  <div class="px-4 max-w-lg mx-auto">
    <p
      class="text-3xl font-black tracking-widest mb-8"
      style="text-shadow: 0 0 20px #FFFFFF;"
    >
      LUMIMIX
    </p>

    <div class="flex justify-center items-center gap-6 mb-8">
      <a
        href="#"
        aria-label="Facebook"
        class="hover:opacity-70 transition-opacity"
      >
        <Image src={facebook} alt="Facebook" width={24} height={24} />
      </a>
      <a href="#" aria-label="X" class="hover:opacity-70 transition-opacity">
        <Image src={x} alt="X" width={24} height={24} />
      </a>
      <a
        href="#"
        aria-label="Instagram"
        class="hover:opacity-70 transition-opacity"
      >
        <Image src={instagram} alt="Instagram" width={24} height={24} />
      </a>
      <a
        href="#"
        aria-label="TikTok"
        class="hover:opacity-70 transition-opacity"
      >
        <Image src={tiktok} alt="TikTok" width={24} height={24} />
      </a>
      <a
        href="#"
        aria-label="YouTube"
        class="hover:opacity-70 transition-opacity"
      >
        <Image src={youtube} alt="YouTube" width={24} height={24} />
      </a>
    </div>

    <nav
      class="flex flex-col gap-2 text-sm font-bold uppercase tracking-widest mb-8"
    >
      <a href="/contact" class="hover:text-rose transition-colors">Contacts</a>
      <a href="/mentions-legales" class="hover:text-rose transition-colors"
        >Mentions legales</a
      >
    </nav>
    <hr class="border-white w-full" />

    <p class="text-xs text-white mt-6">Site web par Leonie PRUNIAUX</p>
  </div>
</footer>
