---
const {
    imgUrl = "",
    day = "",
    nom = "",
    slug = "",
    small = false,
    class: className = "",
    ...rest
} = Astro.props;
---

<a
    href={`/artistes/${slug}`}
    class:list={[
        "artiste-card relative rounded-2xl overflow-hidden block",
        className,
    ]}
    style="aspect-ratio: 3/4;"
    {...rest}
>
    {
        imgUrl && (
            <img
                src={imgUrl}
                alt={nom}
                class="absolute inset-0 w-full h-full object-cover object-center"
                loading="lazy"
            />
        )
    }

    <!-- Gradient -->
    <div
        class="absolute inset-0 bg-linear-to-t from-black/75 via-black/10 to-transparent"
    >
    </div>

    <!-- Badge date -->
    <div
        class:list={[
            "absolute top-3 left-3 bg-rose text-white font-medium uppercase rounded-xl tracking-widest",
            small ? "text-xs px-2 py-0.5" : "text-sm px-3 py-1",
        ]}
    >
        {day}
    </div>

    <!-- Nom artiste -->
    <div class="absolute bottom-4 left-0 right-0 text-center px-3">
        <p
            class:list={[
                "text-white font-black uppercase tracking-wider drop-shadow-lg leading-tight",
                small ? "text-lg md:text-xl" : "text-2xl md:text-3xl",
            ]}
        >
            {nom.toUpperCase()}
        </p>
    </div>
</a>
