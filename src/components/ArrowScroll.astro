---
import { Image } from 'astro:assets';
import fleche from '../assets/img/fleche.svg';
---

<button
  id="arrow-top"
  aria-label="Retour en haut"
  class="fixed bottom-6 right-4 z-50 w-12 h-12 rounded-full bg-rose flex items-center justify-center shadow-lg"
  onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
>
  <Image src={fleche} alt="" width={20} height={20} />
</button>
