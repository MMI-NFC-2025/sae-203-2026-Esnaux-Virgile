---
import persona from "../assets/img/persona.svg";
import billeterie from "../assets/img/billeterie_bouton.svg";
import facebook from "../assets/img/facebook.svg";
import instagram from "../assets/img/instagram.svg";
import x from "../assets/img/x.svg";
import tiktok from "../assets/img/tiktok.svg";
import youtube from "../assets/img/youtube.svg";
---

<!-- ——— HEADER fixe ——— -->
<header
  class="fixed top-0 left-0 right-0 z-50 opacity-100 px-4 py-2 mt-2 flex items-center justify-between"
>
  <!-- Billetterie / LUMIMIX toggle -->
  <a
    id="header-billetterie"
    href="#billetterie"
    class="flex items-center gap-2 bg-rose text-black font-bold text-xs px-4 py-2 rounded-full uppercase tracking-wide hover:bg-white"
  >
    <img src={billeterie.src} alt="Billetterie" width="16" height="16" />
    BILLETTERIE
  </a>
  <a
    id="header-lumimix"
    href="/"
    class="hidden text-white font-black text-xl uppercase tracking-widest"
    style="text-shadow: 0 0 20px #FFFFFF;">LUMIMIX</a
  >

  <!-- Droite -->
  <div class="flex items-center gap-3">
    <!-- Persona visible avec fond blanc pour que l'SVG soit lisible -->
    <a
      href="/connexion"
      aria-label="Mon compte"
      class="w-10 h-10 rounded-full flex items-center justify-center border-3 hover:border-rose transition-colors bg-white"
    >
      <img src={persona.src} alt="Compte" width="20" height="20" />
    </a>

    <!-- Hamburger -->
    <button
      id="menu-toggle"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      class="w-10 h-10 rounded-full bg-rose flex flex-col items-center justify-center gap-1.25 hover:bg-black transition-colors"
    >
      <span
        class="hamburger-bar block w-5 rounded-full bg-white"
        style="height:2px"></span>
      <span
        class="hamburger-bar block w-5 rounded-full bg-white"
        style="height:2px"></span>
      <span
        class="hamburger-bar block w-5 rounded-full bg-white"
        style="height:2px"></span>
    </button>
  </div>
</header>

<!-- ——— OVERLAY ——— -->
<div
  id="nav-overlay"
  class="fixed inset-0 z-40 bg-black hidden flex-col"
  aria-hidden="true"
>
  <!-- Liens + bas -->
  <div class="flex-1 flex flex-col justify-between px-6 py-8 overflow-y-auto">
    <div>
      <p
        class="text-white/50 text-xs font-bold uppercase tracking-[0.25em] mb-6 mt-10"
      >
        MENU
      </p>
      <nav class="flex flex-col gap-5">
        <a
          href="/"
          class="text-white font-black text-2xl uppercase hover:text-rose transition-colors"
          >Accueil</a
        >
        <a
          href="/festival"
          class="text-white font-black text-2xl uppercase hover:text-rose transition-colors"
          >Le Festival</a
        >
        <a
          href="/programmation"
          class="text-white font-black text-2xl uppercase hover:text-rose transition-colors"
          >Programmation</a
        >
        <a
          href="/artistes"
          class="text-white font-black text-2xl uppercase hover:text-rose transition-colors"
          >Artistes</a
        >
        <a
          href="/scenes"
          class="text-white font-black text-2xl uppercase hover:text-rose transition-colors"
          >Scènes</a
        >
        <a
          href="/infos"
          class="text-white font-black text-2xl uppercase hover:text-rose transition-colors"
          >Infos pratiques</a
        >
        <a
          href="/contact"
          class="text-white font-black text-2xl uppercase hover:text-rose transition-colors"
          >Contact</a
        >
      </nav>
    </div>

    <div>
      <button
        class="mb-8 w-10 h-10 rounded-full border border-white/40 text-white text-xs font-bold hover:border-rose transition-colors"
        >FR</button
      >
      <div class="flex items-center gap-6">
        <a
          href="#"
          aria-label="Facebook"
          class="hover:opacity-70 transition-opacity"
        >
          <img src={facebook.src} alt="Facebook" width="24" height="24" />
        </a>
        <a href="#" aria-label="X" class="hover:opacity-70 transition-opacity">
          <img src={x.src} alt="X" width="24" height="24" />
        </a>
        <a
          href="#"
          aria-label="Instagram"
          class="hover:opacity-70 transition-opacity"
        >
          <img src={instagram.src} alt="Instagram" width="24" height="24" />
        </a>
        <a
          href="#"
          aria-label="TikTok"
          class="hover:opacity-70 transition-opacity"
        >
          <img src={tiktok.src} alt="TikTok" width="24" height="24" />
        </a>
        <a
          href="#"
          aria-label="YouTube"
          class="hover:opacity-70 transition-opacity"
        >
          <img src={youtube.src} alt="YouTube" width="24" height="24" />
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .hamburger-bar {
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
    transform-origin: center;
  }
  #menu-toggle.is-open .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  #menu-toggle.is-open .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #menu-toggle.is-open .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  const toggle = document.getElementById("menu-toggle");
  const overlay = document.getElementById("nav-overlay");

  const billetterie = document.getElementById("header-billetterie");
  const lumimix = document.getElementById("header-lumimix");

  function openMenu() {
    overlay?.classList.remove("hidden");
    overlay?.classList.add("flex");
    toggle?.setAttribute("aria-expanded", "true");
    toggle?.setAttribute("aria-label", "Fermer le menu");
    overlay?.setAttribute("aria-hidden", "false");
    toggle?.classList.add("is-open");
    billetterie?.classList.add("hidden");
    lumimix?.classList.remove("hidden");
  }

  function closeMenu() {
    overlay?.classList.remove("flex");
    overlay?.classList.add("hidden");
    toggle?.setAttribute("aria-expanded", "false");
    toggle?.setAttribute("aria-label", "Ouvrir le menu");
    overlay?.setAttribute("aria-hidden", "true");
    toggle?.classList.remove("is-open");
    billetterie?.classList.remove("hidden");
    lumimix?.classList.add("hidden");
  }

  toggle?.addEventListener("click", () => {
    if (toggle.getAttribute("aria-expanded") === "true") closeMenu();
    else openMenu();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMenu();
  });
</script>
