---
import persona from "../assets/img/persona.svg";
import facebook from "../assets/img/facebook.svg";
import instagram from "../assets/img/instagram.svg";
import x from "../assets/img/x.svg";
import tiktok from "../assets/img/tiktok.svg";
import youtube from "../assets/img/youtube.svg";

import "../styles/global.css";
---

<!--  HEADER fixe — pages intérieures (LUMIMIX toujours visible)  -->
<header
  class="fixed top-0 left-0 right-0 z-50 px-4 md:px-8 py-2 md:py-3 mt-2 flex items-center justify-between"
>
  <!-- LUMIMIX toujours visible -->
  <a
    href="/"
    class="font-brand text-white font-black text-xl md:text-3xl uppercase tracking-widest"
    style="text-shadow: 0 0 20px #FFFFFF;"
  >
    LUMIMIX
  </a>

  <!-- Droite -->
  <div class="flex items-center gap-3">
    <a
      href="/connexion"
      aria-label="Mon compte"
      class="w-10 h-10 md:w-24 md:h-24 rounded-full flex items-center justify-center border-3 hover:border-rose transition-colors bg-white"
    >
      <img src={persona.src} alt="Compte" width="20" height="20" />
    </a>

    <button
      id="menu-toggle"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      class="w-10 h-10 md:w-24 md:h-24 rounded-full bg-rose flex flex-col items-center justify-center gap-1.25 hover:bg-black transition-colors"
    >
      <span
        class="hamburger-bar block w-5 rounded-full bg-white"
        style="height:2px"></span>
      <span
        class="hamburger-bar block w-5 rounded-full bg-white"
        style="height:2px"></span>
      <span
        class="hamburger-bar block w-5 rounded-full bg-white"
        style="height:2px"></span>
    </button>
  </div>
</header>

<!--  OVERLAY  -->
<div
  id="nav-overlay"
  class="fixed inset-0 z-40 bg-black flex flex-col opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
  <div
    class="flex-1 flex flex-col justify-between px-6 md:px-20 py-8 md:py-12 overflow-y-auto"
  >
    <div>
      <p
        class="text-white text-page-title font-bold uppercase tracking-[0.10em] mb-6 mt-20 gap-2"
      >
        MENU
      </p>
      <nav class="flex flex-col gap-3 md:gap-6">
        <a
          href="/"
          class="text-white font-black text-xl md:text-5xl uppercase hover:text-rose transition-colors"
          >Accueil</a
        >
        <a
          href="/festival"
          class="text-white font-black text-xl md:text-5xl uppercase hover:text-rose transition-colors"
          >Le Festival</a
        >
        <a
          href="/programmation"
          class="text-white font-black text-xl md:text-5xl uppercase hover:text-rose transition-colors"
          >Programmation</a
        >
        <a
          href="/artistes"
          class="text-white font-black text-xl md:text-5xl uppercase hover:text-rose transition-colors"
          >Artistes</a
        >
        <a
          href="/scenes"
          class="text-white font-black text-xl md:text-5xl uppercase hover:text-rose transition-colors"
          >Scenes</a
        >
        <a
          href="/infos"
          class="text-white font-black text-xl md:text-5xl uppercase hover:text-rose transition-colors"
          >Infos pratiques</a
        >
        <a
          href="/contact"
          class="text-white font-black text-xl md:text-5xl uppercase hover:text-rose transition-colors"
          >Contact</a
        >
      </nav>
    </div>

    <div>
      <button
        class="mt-10 mb-10 w-10 h-10 md:w-24 md:h-24 rounded-full border border-white/40 bg-white text-black text-xs md:text-xl font-bold hover:border-rose transition-colors"
        >FR</button
      >
      <div class="flex items-center gap-6 md:gap-10">
        <a
          href="https://www.facebook.com/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="hover:opacity-70 transition-opacity"
        >
          <img
            src={facebook.src}
            alt="Facebook"
            width="24"
            height="24"
            class="md:w-16 md:h-16"
          />
        </a>
        <a
          href="https://x.com/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="X"
          class="hover:opacity-70 transition-opacity"
        >
          <img
            src={x.src}
            alt="X"
            width="24"
            height="24"
            class="md:w-16 md:h-16"
          />
        </a>
        <a
          href="https://www.instagram.com/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="hover:opacity-70 transition-opacity"
        >
          <img
            src={instagram.src}
            alt="Instagram"
            width="24"
            height="24"
            class="md:w-16 md:h-16"
          />
        </a>
        <a
          href="https://www.tiktok.com/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="TikTok"
          class="hover:opacity-70 transition-opacity"
        >
          <img
            src={tiktok.src}
            alt="TikTok"
            width="24"
            height="24"
            class="md:w-16 md:h-16"
          />
        </a>
        <a
          href="https://www.youtube.com/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="YouTube"
          class="hover:opacity-70 transition-opacity"
        >
          <img
            src={youtube.src}
            alt="YouTube"
            width="24"
            height="24"
            class="md:w-16 md:h-16"
          />
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .hamburger-bar {
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
    transform-origin: center;
  }
  #menu-toggle.is-open .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  #menu-toggle.is-open .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #menu-toggle.is-open .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  const toggle = document.getElementById("menu-toggle");
  const overlay = document.getElementById("nav-overlay");

  function openMenu() {
    overlay?.classList.remove("opacity-0", "pointer-events-none");
    overlay?.classList.add("opacity-100");
    toggle?.setAttribute("aria-expanded", "true");
    toggle?.setAttribute("aria-label", "Fermer le menu");
    overlay?.setAttribute("aria-hidden", "false");
    toggle?.classList.add("is-open");
  }

  function closeMenu() {
    overlay?.classList.remove("opacity-100");
    overlay?.classList.add("opacity-0", "pointer-events-none");
    toggle?.setAttribute("aria-expanded", "false");
    toggle?.setAttribute("aria-label", "Ouvrir le menu");
    overlay?.setAttribute("aria-hidden", "true");
    toggle?.classList.remove("is-open");
  }

  toggle?.addEventListener("click", () => {
    if (toggle.getAttribute("aria-expanded") === "true") closeMenu();
    else openMenu();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMenu();
  });
</script>
