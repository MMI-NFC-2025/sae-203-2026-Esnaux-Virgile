---

<div class="relative flex items-center gap-4" data-carousel>
    <button
        data-carousel-prev
        aria-label="Précédent"
        class="shrink-0 w-11 h-11 rounded-full border-2 border-white/60 flex items-center justify-center text-white text-lg font-bold hover:border-rose hover:text-rose transition-colors"
    >
        &#8592;
    </button>

    <div
        data-carousel-viewport
        class="flex-1 overflow-x-hidden flex snap-x snap-mandatory items-center py-4"
    >
        <slot />
    </div>

    <button
        data-carousel-next
        aria-label="Suivant"
        class="shrink-0 w-11 h-11 rounded-full border-2 border-white/60 flex items-center justify-center text-white text-lg font-bold hover:border-rose hover:text-rose transition-colors"
    >
        &#8594;
    </button>
</div>

<script>
    document.querySelectorAll("[data-carousel]").forEach((carousel) => {
        const viewport = carousel.querySelector(
            "[data-carousel-viewport]",
        ) as HTMLElement;
        const prev = carousel.querySelector("[data-carousel-prev]");
        const next = carousel.querySelector("[data-carousel-next]");

        const scrollByOne = (dir: number) => {
            const itemWidth =
                (viewport?.firstElementChild as HTMLElement)?.offsetWidth ??
                200;
            viewport?.scrollBy({ left: dir * itemWidth, behavior: "smooth" });
        };

        prev?.addEventListener("click", () => scrollByOne(-1));
        next?.addEventListener("click", () => scrollByOne(1));
    });
</script>
