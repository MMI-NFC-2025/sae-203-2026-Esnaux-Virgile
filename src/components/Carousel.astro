---

<div class="relative flex items-center gap-4">
    <button
        id="carousel-prev"
        aria-label="Precedent"
        class="shrink-0 w-11 h-11 rounded-full border-2 border-white/60 flex items-center justify-center text-white text-lg font-bold hover:border-rose hover:text-rose transition-colors"
    >
        &#8592;
    </button>

    <div
        id="carousel-viewport"
        class="flex-1 overflow-x-auto flex gap-8 snap-x snap-mandatory items-center justify-center py-4"
        style="scrollbar-width: none; -ms-overflow-style: none;"
    >
        <slot />
    </div>

    <button
        id="carousel-next"
        aria-label="Suivant"
        class="shrink-0 w-11 h-11 rounded-full border-2 border-white/60 flex items-center justify-center text-white text-lg font-bold hover:border-rose hover:text-rose transition-colors"
    >
        &#8594;
    </button>
</div>

<script>
    const viewport = document.getElementById("carousel-viewport");
    document.getElementById("carousel-prev")?.addEventListener("click", () => {
        viewport?.scrollBy({ left: -200, behavior: "smooth" });
    });
    document.getElementById("carousel-next")?.addEventListener("click", () => {
        viewport?.scrollBy({ left: 200, behavior: "smooth" });
    });
</script>
